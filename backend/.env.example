# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/dealmate?retryWrites=true&w=majority

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d
SALT_ROUNDS=10

# ─── Frontend (CORS) ─────────────────────────────────────────────────────────
FRONTEND_URL=https://your-frontend.onrender.com
CORS_ORIGIN=https://your-frontend.onrender.com

# ─── Email (Gmail SMTP) ──────────────────────────────────────────────────────
MAIL_PROVIDER=gmail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USER=your-email@gmail.com
MAIL_PASS=your_gmail_app_password
MAIL_FROM="DealMate <your-email@gmail.com>"

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ─── Gemini AI ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# ─── Khalti ──────────────────────────────────────────────────────────────────
KHALTI_SECRET_KEY=your_khalti_secret_key

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUD_NAME=your_cloud_name
CLOUD_API_KEY=your_cloud_api_key
CLOUD_API_SECRET=your_cloud_api_secret

# ─── ORS (OpenRouteService) ──────────────────────────────────────────────────
ORS_API_KEY=your_ors_api_key

# ─── AI Microservices ────────────────────────────────────────────────────────
RECOMMENDER_SERVICE_URL=https://your-recommender.onrender.com
SENTIMENT_SERVICE_URL=https://your-sentiment.onrender.com
